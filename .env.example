# Quantlytics (Itera engine) environment example
# Copy to .env for local development.

ENVIRONMENT=development
LOG_LEVEL=INFO

# API security
# Comma-separated list of accepted API keys for X-API-Key.
QUANTLYTICS_API_KEYS=dev-local-key-change-me
QUANTLYTICS_CORS_ORIGINS=http://localhost:3000,http://localhost:8501
QUANTLYTICS_RATE_LIMIT_PER_MINUTE=120

# Broker keys (required for live trading only)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Data providers (optional for demos)
NEWS_API_KEY=
FRED_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=quantlytics/1.0

# Infrastructure
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://trader:${POSTGRES_PASSWORD}@postgres:5432/trading_ai
REDIS_URL=redis://redis:6379/0
